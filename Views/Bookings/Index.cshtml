@model IEnumerable<EventEaseBookingSystem.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<h1 class="mb-4">Bookings</h1>

<!-- ERROR MESSAGE -->
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<!-- SEARCH BAR -->
<form asp-action="Search" method="get" class="mb-3">
    <div class="row">
        <div class="col-md-6">
            <input type="text"
                   name="query"
                   class="form-control"
                   placeholder="Search by Booking ID or Event Name..." />
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-dark w-100">
                Search
            </button>
        </div>

        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-secondary w-100">
                Reset
            </a>
        </div>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">
        Create New Booking
    </a>
</p>

<table class="table table-bordered table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Booking ID</th>
            <th>Customer Name</th>
            <th>Booking Date</th>
            <th>Venue</th>
            <th>Event</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @item.BookingId
                </td>

                <td>
                    @item.CustomerName
                </td>

                <td>
                    @item.BookingDate
                </td>

                <td>
                    @item.Venue?.Location
                </td>

                <td>
                    @item.Event?.EventName
                </td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@item.BookingId"
                       class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a asp-action="Details"
                       asp-route-id="@item.BookingId"
                       class="btn btn-info btn-sm text-white">
                        Details
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.BookingId"
                       class="btn btn-danger btn-sm">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
@model IEnumerable<EventEaseBookingSystem.Models.Event>
@using System.Collections.Generic

@{
    ViewData["Title"] = "Events";
    var bookedEventIds = ViewData["BookedEventIds"] as List<int> ?? new List<int>();
}

<h1>Events</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<form asp-action="Index" method="get" class="card card-body mb-3">
    <h5>Advanced Search and Filtering</h5>

    <div class="row g-2">
        <div class="col-md-3">
            <label class="form-label">Search</label>
            <input type="text" name="searchString" value="@ViewData["CurrentSearch"]" class="form-control" placeholder="Event, venue, location, type" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Event Type</label>
            <select name="eventTypeId" class="form-control" asp-items="ViewBag.EventTypeFilter">
                <option value="">All Types</option>
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label">Venue</label>
            <select name="venueId" class="form-control" asp-items="ViewBag.VenueFilter">
                <option value="">All Venues</option>
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label">From Date</label>
            <input type="date" name="startDate" value="@ViewData["CurrentStartDate"]" class="form-control" />
        </div>

        <div class="col-md-2">
            <label class="form-label">To Date</label>
            <input type="date" name="endDate" value="@ViewData["CurrentEndDate"]" class="form-control" />
        </div>

        <div class="col-md-1 d-flex align-items-end">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="availableOnly" value="true" @(ViewData["AvailableOnly"] is true ? "checked" : "") />
                <label class="form-check-label">Available</label>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-dark">Apply Filters</button>
        <a asp-action="Index" class="btn btn-secondary">Reset</a>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Event</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Event Name</th>
            <th>Event Type</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Venue</th>
            <th>Availability</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.EventName</td>
                    <td>@item.EventType?.Name</td>
                    <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.EndDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.Venue?.Name</td>
                    <td>
                        @if (bookedEventIds.Contains(item.EventId))
                        {
                            <span class="badge bg-danger">Booked</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Available</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.EventId">Edit</a> |
                        <a asp-action="Details" asp-route-id="@item.EventId">Details</a> |
                        <a asp-action="Delete" asp-route-id="@item.EventId">Delete</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center">No events match the selected filters</td>
            </tr>
        }
    </tbody>
</table>
